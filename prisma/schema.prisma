generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
  REPORTER
  CONTRIBUTOR
  ADVERTISER
  SUBSCRIBER
}

enum ArticleStatus {
  DRAFT
  REVIEW
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum EventStatus {
  PENDING
  APPROVED
  REJECTED
}

enum GameStatus {
  UPCOMING
  LIVE
  FINAL
}

enum BreakingLevel {
  ALERT
  WEATHER
  URGENT
}

enum ArchiveSource {
  HERALD
  CHIEFTAIN
  OBSERVER
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  role           Role      @default(SUBSCRIBER)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  accounts       Account[]
  sessions       Session[]
  articles       Article[] @relation("ArticleAuthor")
  auditLogs      AuditLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Article {
  id            String        @id @default(cuid())
  slug          String        @unique
  title         String
  dek           String
  category      String
  locality      String
  status        ArticleStatus @default(DRAFT)
  featured      Boolean       @default(false)
  heroImage     String?
  heroCaption   String?
  heroCredit    String?
  body          String
  tags          String[]
  wordCount     Int           @default(0)
  isDemo        Boolean       @default(false)
  subscriberOnly Boolean      @default(false)
  publishedAt   DateTime?
  scheduledAt   DateTime?
  authorId      String?
  author        User?         @relation("ArticleAuthor", fields: [authorId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([category, status])
  @@index([locality])
  @@index([publishedAt])
  @@index([title])
}

model Obituary {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  age             Int?
  city            String
  diedOn          DateTime
  serviceAt       String?
  serviceLocation String?
  summary         String
  photo           String?
  isDemo          Boolean  @default(true)
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([name])
  @@index([diedOn])
}

model Event {
  id          String      @id @default(cuid())
  slug        String      @unique
  title       String
  date        DateTime
  time        String
  city        String
  venue       String
  category    String
  price       String      @default("Free")
  description String
  status      EventStatus @default(PENDING)
  isDemo      Boolean     @default(false)
  submitterEmail String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([date, status])
  @@index([city])
}

model Gallery {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  eventName    String
  date         DateTime
  photographer String
  coverImage   String
  images       String[]
  isDemo       Boolean  @default(false)
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Game {
  id        String     @id @default(cuid())
  homeTeam  String
  awayTeam  String
  homeScore Int?
  awayScore Int?
  date      DateTime
  sport     String
  status    GameStatus @default(UPCOMING)
  isDemo    Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model PublicNotice {
  id        String   @id @default(cuid())
  title     String
  type      String
  agency    String
  city      String
  county    String
  date      DateTime
  summary   String
  isDemo    Boolean  @default(false)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([county])
}

model Classified {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  category  String
  price     String?
  city      String
  summary   String
  status    EventStatus @default(PENDING)
  isDemo    Boolean  @default(false)
  postedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DirectoryListing {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  category  String
  city      String
  phone     String
  address   String
  summary   String
  sponsored Boolean  @default(false)
  isDemo    Boolean  @default(false)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobPosting {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  employer  String
  city      String
  type      String
  summary   String
  postedAt  DateTime @default(now())
  isDemo    Boolean  @default(false)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ArchiveEdition {
  id         String        @id @default(cuid())
  year       Int
  month      String
  title      String
  source     ArchiveSource
  coverLabel String
  externalUrl String?
  isDemo     Boolean       @default(false)
  createdAt  DateTime      @default(now())

  @@index([year])
}

model BreakingNews {
  id        String        @id @default(cuid())
  enabled   Boolean       @default(false)
  text      String
  href      String
  level     BreakingLevel @default(URGENT)
  sticky    Boolean       @default(false)
  expiresAt DateTime?
  updatedAt DateTime      @updatedAt
  createdAt DateTime      @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  lists     String[]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model MediaAsset {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  credit    String?
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String?
  entityId  String?
  meta      String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
